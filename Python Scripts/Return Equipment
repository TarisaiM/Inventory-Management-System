import cv2
import pyzbar.pyzbar as pyzbar
import datetime
import time
import tkinter as tk
from tkinter import messagebox
import urllib.request
import json

# Global variable to store scanned employee ID from QR code
employee_id = ""

#  QR CODE SCANNER 
def scan_qr_code():
    global employee_id

    # Start webcam (0 = default camera)
    cam = cv2.VideoCapture(0)

    # Set camera width and height
    cam.set(3, 640)
    cam.set(4, 480)

    while True:
        success, frame = cam.read()

        # If frame is not captured properly, stop scanning
        if not success:
            print("Failed to capture frame")
            break

        # Decode QR codes from the camera frame
        decoded_objects = pyzbar.decode(frame)

        # Loop through detected QR codes
        for obj in decoded_objects:
            # Convert QR data to string (employee ID)
            employee_id = obj.data.decode("utf-8")

            print("QR Detected:", employee_id)

            # Small delay to avoid multiple scans
            time.sleep(2)
            cam.release()
            cv2.destroyAllWindows()

            return employee_id

        # Show camera feed window
        cv2.imshow("Return Equipment Scanner", frame)

        # Press 'q' to quit scanning manually
        if cv2.waitKey(1) & 0xFF == ord("q"):
            break

    # Release camera if loop ends
    cam.release()
    cv2.destroyAllWindows()
    return None

# PROCESS EQUIPMENT RETURN 
def process_return():
    global employee_id

    # Get booking ID entered by user
    booking_id = entry.get()

    # Validate input
    if not booking_id:
        messagebox.showerror("Error", "Please enter Booking ID")
        return

    # Get today's date as return date
    return_date = datetime.date.today()

    # Start QR scan to get employee ID
    employee_id = scan_qr_code()

    if not employee_id:
        messagebox.showerror("Error", "QR scan failed")
        return

    # API endpoint for returning equipment
    url = "yourapiurl"

    # Data payload sent to API (converted to JSON)
    payload = json.dumps({
        "r_date": str(return_date),
        "booking_id": int(booking_id),
        "emp_id": int(employee_id)
    }).encode("utf-8")

    # Create HTTP POST request
    req = urllib.request.Request(
        url,
        data=payload,
        method="POST",
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
            "User-Agent": "Mozilla/5.0"
        }
    )

    try:
        # Send request to API
        with urllib.request.urlopen(req) as response:
            response_text = response.read().decode()

        # Print API response for debugging
        print("SUCCESS RESPONSE:")
        print(response_text)

        messagebox.showinfo("Success", "Equipment return processed successfully")

    except urllib.error.HTTPError as e:
        error_body = e.read().decode()

        print("HTTP ERROR:", e.code)
        print(error_body)

        messagebox.showerror("Error", f"HTTP Error {e.code}")


#  GUI SETUP 

# Create main application window
root = tk.Tk()
root.title("Equipment Return System")

tk.Label(root, text="Enter Booking ID:").pack(pady=5)

# Input field for booking ID
entry = tk.Entry(root)
entry.pack(pady=5)

# Button to start process (booking + QR scan + return)
tk.Button(
    root,
    text="Submit and Scan QR Code",
    command=process_return
).pack(pady=10)

root.mainloop()
