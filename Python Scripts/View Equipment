import urllib.request
import json
import tkinter as tk
from tkinter import ttk, messagebox

# Function to fetch and display inventory usage history for a specific employee
def get_inventory_usage_history(employee_id):
    try:
        # API endpoint that returns inventory booking data
        url = "https://oracleapex.com/ords/tarisaimachoba/api/inventory/getreport"

       
        req = urllib.request.Request(
            url,
            headers={
                "Accept": "application/json",
                "User-Agent": "Mozilla/5.0"
            }
        )

        # Send request and read response from API
        with urllib.request.urlopen(req) as response:
            response_text = response.read().decode("utf-8")

        # Convert JSON string into Python dictionary
        booking_data = json.loads(response_text)

        # Check if API response has the expected structure
        if "items" not in booking_data:
            messagebox.showerror("Error", "Invalid API response (missing 'items')")
            return

        # Filter only records that belong to the given employee ID
        filtered_data = [
            item for item in booking_data["items"]
            if item.get("employee_id") == employee_id
        ]

        # If no records found for this employee
        if not filtered_data:
            messagebox.showinfo(
                "No Records",
                f"No bookings found for employee ID {employee_id}"
            )
            return

        # Create a new window to display the report
        report_window = tk.Toplevel(root)
        report_window.title("Inventory Usage Report")
        report_window.geometry("900x400")

        # Define table columns
        columns = (
            "Booking ID",
            "Date Booked",
            "Date Returned",
            "Employee ID",
            "Equipment ID"
        )

        # Create table (Treeview widget)
        tree = ttk.Treeview(report_window, columns=columns, show="headings")

        # Set column headings and width
        for col in columns:
            tree.heading(col, text=col)
            tree.column(col, width=160)

        tree.pack(fill="both", expand=True)

        # Insert filtered data into the table
        for item in filtered_data:
            tree.insert(
                "",
                tk.END,
                values=(
                    item.get("booking_id"),
                    item.get("date_booked"),
                    item.get("date_returned"),
                    item.get("employee_id"),
                    item.get("equipment_id")
                )
            )

    # Show error message if anything goes wrong
    except Exception as e:
        messagebox.showerror("Error", str(e))


# Function triggered when user clicks "Get Report"
def open_report_window():
    try:
        # Get employee ID from input field and convert to integer
        employee_id = int(entry.get())

        # Call function to fetch and display report
        get_inventory_usage_history(employee_id)

    except ValueError:
        # Handle invalid input (non-numeric)
        messagebox.showerror("Error", "Enter a valid numeric employee ID")


#  GUI SETUP 

# Create main application window
root = tk.Tk()
root.title("Inventory Usage Report")
root.geometry("350x150")

# Label for input field
tk.Label(root, text="Enter Employee ID:").pack(pady=10)

# Input field for employee ID
entry = tk.Entry(root)
entry.pack(pady=5)

# Button to trigger report generation
tk.Button(root, text="Get Report", command=open_report_window).pack(pady=10)

# Start the GUI event loop
root.mainloop()
